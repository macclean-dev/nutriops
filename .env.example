# NutriOPS — environment variables
# Copie esse arquivo pra .env.local e preencha. .env.local nunca vai pro git.
# Em produção, configure essas mesmas variáveis em Vercel → Project → Settings → Environment Variables.

# Senha do painel admin (https://nutriops.uniwares.net/admin)
# Sem isso, o fallback hardcoded é usado e um aviso aparece no console.
VITE_ADMIN_PASSWORD=troque-essa-senha-forte
