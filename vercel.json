{
  "rewrites": [
    { "source": "/landing-nutriops.html", "destination": "/landing-nutriops.html" },
    { "source": "/manual-nutriops.html",  "destination": "/manual-nutriops.html"  },
    { "source": "/(.*)",                  "destination": "/index.html"            }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control",          "value": "no-cache" },
        { "key": "Service-Worker-Allowed", "value": "/"        }
      ]
    }
  ]
}
